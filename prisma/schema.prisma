generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  admin
  ops
}

enum TicketStatus {
  open
  in_progress
  blocked
  done
}

enum TicketPriority {
  low
  medium
  high
  urgent
}

model User {
  id           String    @id @default(cuid())
  email        String    @unique
  passwordHash String
  role         UserRole  @default(ops)

  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  assignedTickets Ticket[] @relation("TicketAssignee")

  @@index([role])
}

model Ticket {
  id          String         @id @default(cuid())
  title       String
  description String
  status      TicketStatus   @default(open)
  priority    TicketPriority @default(medium)
  tags        String[]       @default([])

  assigneeId  String?
  assignee    User?          @relation("TicketAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)

  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@index([status])
  @@index([priority])
  @@index([assigneeId])
  @@index([createdAt])
}

model KBItem {
  id        String   @id @default(cuid())
  title     String
  content   String
  tags      String[] @default([])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([createdAt])
}

model IdempotencyKey {
  id           String   @id @default(cuid())
  key          String
  route        String
  userId       String?
  requestHash  String
  responseBody Json?
  statusCode   Int?
  expiresAt    DateTime

  createdAt    DateTime @default(now())

  @@unique([key, route])
  @@index([expiresAt])
  @@index([userId])
}